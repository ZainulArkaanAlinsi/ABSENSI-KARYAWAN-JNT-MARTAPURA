rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Role helpers ──────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin');
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // ── Admin catch-all ───────────────────────────────────────
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuth() && isOwner(userId)
        && !request.resource.data.diff(resource.data)
            .affectedKeys().hasAny(['role', 'employeeId', 'department', 'email', 'uid']);
    }

    // ── Attendance ────────────────────────────────────────────
    // resource == null → dokumen belum ada (transaction.get saat check-in
    // pertama hari itu). Tanpa ini, transaction.get ditolak → "gagal
    // menyimpan absensi".
    match /attendance/{attendanceId} {
      allow read: if isAuth() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Leave requests ────────────────────────────────────────
    match /leaves/{leaveId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && isOwner(resource.data.userId) && resource.data.status == 'pending';
    }

    // ── Overtime ──────────────────────────────────────────────
    // Owner bisa create / cancel selama status masih 'pending'.
    // Admin write (approve/reject) di-handle catch-all rule di atas.
    match /overtime/{overtimeId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid
                                  && request.resource.data.status == 'pending';
      allow update: if isAuth() && isOwner(resource.data.userId)
                                  && resource.data.status == 'pending';
      allow delete: if isAuth() && isOwner(resource.data.userId)
                                  && resource.data.status == 'pending';
    }

    // ── Notifications (personal) ──────────────────────────────
    match /userNotifications/{notifId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAdmin();
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Broadcasts (read-only for employees) ──────────────────
    match /broadcasts/{broadcastId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── Calendar events ───────────────────────────────────────
    match /calendarEvents/{eventId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ── FCM tokens ────────────────────────────────────────────
    match /fcm_tokens/{tokenId} {
      allow read: if isAdmin();
      allow write: if isAuth();
    }

    // ── Chat messages (flat collection, filtered by chatId) ───
    // Room-based chat: setiap room dikunci ke userId (chatId == userId).
    // Admin boleh akses semua room; user hanya room miliknya sendiri.
    // chatId dipakai di filter query supaya rules query-safe (bukan filter).
    match /messages/{messageId} {
      allow read: if isAuth() && (
        isAdmin() ||
        resource.data.chatId == request.auth.uid
      );
      allow create: if isAuth() && (
        isAdmin() ||
        (request.resource.data.senderId == request.auth.uid &&
         request.resource.data.chatId == request.auth.uid)
      );
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.chatId == request.auth.uid
      );
    }

    // ── Chat metadata + typing indicators ────────────────────
    match /chats/{chatId} {
      allow read, write: if isAuth();
      match /typing/{docId} {
        allow read, write: if isAuth();
      }
    }

    // ── SOS alerts ────────────────────────────────────────────
    match /sos_alerts/{sosId} {
      allow create: if isAuth();
      allow read, update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // ── Admin notifications (created by employee to alert admin)
    match /adminNotifications/{notifId} {
      allow create: if isAuth();
      allow read: if isAuth() && (resource.data.employeeId == request.auth.uid || isAdmin());
    }

    // ── Audit log ─────────────────────────────────────────────
    match /audit_log/{logId} {
      allow create: if isAuth();
      allow read: if isAdmin();
    }

    // ── Attendance edit requests (employee-submitted) ─────────
    match /edit_requests/{reqId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    // ── Online presence ───────────────────────────────────────
    match /user_presence/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.auth.uid == userId;
    }

    // ── Disputes / sanggahan (two-way thread user ↔ admin) ────
    match /disputes/{disputeId} {
      allow read:   if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());

      // Pesan thread: subkoleksi disputes/{id}/messages
      match /messages/{msgId} {
        allow read, create: if isAuth() && (
          isAdmin() ||
          get(/databases/$(database)/documents/disputes/$(disputeId)).data.userId == request.auth.uid
        );
      }
    }

    // ── Leave balances (kuota cuti di-set admin, user baca punya sendiri) ──
    match /leave_balances/{userId} {
      allow read:  if isAuth() && (isOwner(userId) || isAdmin());
      allow write: if isAdmin();
    }

    // ── Login issues (dilapor user yg BELUM bisa login → unauthenticated) ──
    // Create dibuka (user blm punya akun/sesi); baca & kelola admin only.
    match /login_issues/{issueId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ── Read-only shared data ─────────────────────────────────
    match /shifts/{shiftId}      { allow read: if isAuth(); }
    match /departments/{deptId}  { allow read: if isAuth(); }
    match /settings/{settingId}  { allow read: if isAuth(); }
    match /jamKerja/{id}         { allow read: if isAuth(); }
  }
}
